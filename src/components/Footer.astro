---
const { locale = 'en' } = Astro.props;
const t = locale === 'id' ? {
  tagline: 'Dakarash as Logistics Solutions',
  services: 'Layanan',
  contact: 'Kontak',
  contactUs: 'Hubungi Kami →',
  rights: 'All rights reserved.',
  links: [
    { label: 'Project Cargo', href: '/id/services' },
    { label: 'Dry Bulk & Mineral', href: '/id/services' },
    { label: 'Forwarding', href: '/id/services' },
    { label: 'Customs Clearance', href: '/id/services' },
    { label: 'Supply Chain', href: '/id/services' },
  ],
} : {
  tagline: 'Dakarash as Logistics Solutions',
  services: 'Services',
  contact: 'Contact',
  contactUs: 'Contact Us →',
  rights: 'All rights reserved.',
  links: [
    { label: 'Project Cargo', href: '/services' },
    { label: 'Dry Bulk & Mineral', href: '/services' },
    { label: 'Forwarding', href: '/services' },
    { label: 'Customs Clearance', href: '/services' },
    { label: 'Supply Chain', href: '/services' },
  ],
};
---

<footer>
  <div class="container">
    <div class="grid">
      <div class="col">
        <img src="/images/logo_white.png" alt="Dakarash" height="32" />
        <p class="tagline">{t.tagline}</p>
      </div>
      <div class="col">
        <h4>{t.services}</h4>
        {t.links.map((link) => (
          <a href={link.href}>{link.label}</a>
        ))}
      </div>
      <div class="col">
        <h4>{t.contact}</h4>
        <p>info@dakarash.co.id</p>
        <p>0813-8267-9512</p>
        <p>&nbsp;</p>
        <a href={locale === 'id' ? '/id/contact' : '/contact'} class="footer-link">{t.contactUs}</a>
      </div>
    </div>
    <div class="bottom">
      <p>&copy; {new Date().getFullYear()} Dakarash. {t.rights}</p>
    </div>
  </div>
</footer>

<style>
  footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 4rem 0 0;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
  }
  .col h4 {
    color: #fff;
    margin-bottom: 1rem;
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .col p { margin-bottom: 0.5rem; line-height: 1.7; }
  .col a {
    display: block;
    color: #94a3b8;
    margin-bottom: 0.5rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  .col a:hover { color: #fff; }
  .tagline {
    color: #60a5fa;
    font-weight: 500;
    margin-top: 0.75rem;
  }
  .footer-link { color: #60a5fa !important; font-weight: 500; }
  .bottom {
    border-top: 1px solid rgba(255,255,255,0.06);
    padding: 1.5rem 0;
    text-align: center;
    font-size: 0.85rem;
  }
  @media (max-width: 768px) {
    .grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
