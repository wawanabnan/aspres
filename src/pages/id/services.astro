---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';

const serviceModules = import.meta.glob('../../../data/id/id/services/*.json', { eager: true });
const services = Object.values(serviceModules).map(m => m.default);

const details = {
  'Project Cargo Logistics': {
    items: [
      'Studi Kelayakan Rute (Route Survey) & analisis kekuatan infrastruktur',
      'Pengurusan perizinan jalan khusus dan pengawalan kepolisian (escort)',
      'Manajemen Multi-Moda — trailer multi-axle, sewa kapal tongkang, heavy-crane',
      'Pengawasan ketat di lokasi (on-site supervision) sesuai standar HSE',
    ],
  },
  'Dry Bulk & Mineral Logistics': {
    items: [
      'Mobilisasi angkutan darat dari area konsesi tambang ke stockpile & jetty',
      'Pemuatan tongkang hingga transshipment ke mother vessel',
      'Manajemen waktu presisi untuk menghindari risiko demurrage',
      'Pengurusan dokumen domestik (SKAB), kepabeanan ekspor, koordinasi surveyor',
    ],
  },
  'Forwarding (Darat, Laut, & Udara)': {
    items: [
      'Full Container Load (FCL) & Less Container Load (LCL)',
      'Air Freight untuk komoditas time-sensitive',
      'Konsolidasi kargo dari berbagai titik asal untuk efisiensi biaya',
    ],
  },
  'Customs Clearance & Compliance': {
    items: [
      'Pengurusan PEB/PIB (ekspor-impor)',
      'Pemeriksaan jalur kepabeanan (Hijau, Kuning, Merah)',
      'Konsultasi HS Code, bea masuk, pajak, & fasilitas kepabeanan',
    ],
  },
  'Supply Chain Solutions & Contract Logistics': {
    items: [
      'Optimasi rute distribusi hulu-ke-hilir',
      'Manajemen penyimpanan & kontrol inventaris terintegrasi digital',
      'Single Point of Contact untuk seluruh aktivitas logistik',
    ],
  },
};
---

<Layout title="Layanan - Dakarash">
  <Navbar locale="id" />
  <main>
    <section class="hero-sm">
      <div class="container">
        <div class="section-label">LAYANAN</div>
        <h1>Kompetensi Logistik Kami</h1>
        <p>Dari kargo proyek berskala besar hingga distribusi reguler — kami hadirkan solusi logistik menyeluruh untuk bisnis Anda.</p>
      </div>
    </section>

    <section class="services-list">
      <div class="container">
        {services.map((svc, i) => {
          const detail = details[svc.title] || { items: [] };
          return (
          <div class="service-item">
            <div class="service-header">
              <span class="service-num">0{i + 1}</span>
              <h2>{svc.title}</h2>
            </div>
            <p class="service-desc">{svc.description}</p>
            <div class="service-items">
              {detail.items.map((item) => (
                <div class="service-bullet">
                  <span class="check">✓</span>
                  <span>{item}</span>
                </div>
              ))}
            </div>
          </div>
          );
        })}
      </div>
    </section>
  </main>
  <WhatsApp />
  <Footer locale="id" />
</Layout>

<style>
  .hero-sm {
    background: linear-gradient(135deg, #0c1426, #1e3a5f);
    color: #fff;
    padding: 5rem 0 4rem;
    text-align: center;
  }
  .hero-sm h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
  }
  .hero-sm p {
    color: #94a3b8;
    font-size: 1.1rem;
    max-width: 650px;
    margin: 0 auto;
    line-height: 1.7;
  }
  .section-label {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    color: #60a5fa;
    margin-bottom: 0.75rem;
  }
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .services-list {
    padding: 4rem 0;
  }
  .service-item {
    padding: 2.5rem;
    margin-bottom: 1.5rem;
    border-radius: 16px;
    border: 1px solid #f1f5f9;
    background: #fff;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    transition: box-shadow 0.2s;
  }
  .service-item:hover {
    box-shadow: 0 8px 32px rgba(0,0,0,0.08);
  }
  .service-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .service-num {
    font-size: 0.9rem;
    font-weight: 700;
    color: #2563eb;
    background: #eff6ff;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
  }
  .service-header h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1.35rem;
  }
  .service-desc {
    color: #475569;
    font-size: 1.05rem;
    margin-bottom: 1.25rem;
    line-height: 1.7;
  }
  .service-items { display: flex; flex-direction: column; gap: 0.75rem; }
  .service-bullet {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: #475569;
    line-height: 1.6;
  }
  .check {
    color: #16a34a;
    font-weight: 700;
    flex-shrink: 0;
  }
  @media (max-width: 768px) {
    .hero-sm h1 { font-size: 1.75rem; }
    .service-item { padding: 1.5rem; }
  }
</style>


