---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';
import data from '../../data/id/technology.json';
---

<Layout title="Technology - Dakarash | Powered by Kargopath">
  <Navbar locale="id" />
  <main>
    <section class="header-section">
      <div class="container">
        <h1>{data.title}</h1>
        <p class="subtitle">{data.subtitle}</p>
        <p>{data.description}</p>
      </div>
    </section>

    <section class="features">
      <div class="container">
        {data.features.map((feature) => (
          <div class="feature">
            <div class="feature-text">
              <h2>{feature.title}</h2>
              <p>{feature.text}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="cta">
      <div class="container">
        <h2>{data.cta_heading}</h2>
        <p>{data.cta_text}</p>
        <a href={data.cta_button_url} class="btn">{data.cta_button_text}</a>
      </div>
    </section>
  </main>
  <WhatsApp />
  <Footer locale="id" />
</Layout>

<style>
  .header-section {
    background: linear-gradient(135deg, #0f172a, #1e3a5f);
    color: #fff;
    padding: 5rem 0;
    text-align: center;
  }
  .header-section h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .header-section .subtitle {
    color: #60a5fa;
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }
  .header-section p {
    color: #94a3b8;
    font-size: 1.1rem;
    max-width: 650px;
    margin: 0 auto;
  }
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }
  .features {
    padding: 4rem 0;
  }
  .feature {
    padding: 2rem 0;
    border-bottom: 1px solid #e2e8f0;
  }
  .feature:last-child {
    border-bottom: none;
  }
  .feature-text h2 {
    color: #0f172a;
    margin-bottom: 0.75rem;
  }
  .feature-text p {
    color: #64748b;
    line-height: 1.8;
  }
  .cta {
    background: #f8fafc;
    text-align: center;
    padding: 4rem 0;
  }
  .cta h2 {
    color: #0f172a;
    margin-bottom: 0.75rem;
  }
  .cta p {
    color: #64748b;
    margin-bottom: 2rem;
  }
  .btn {
    display: inline-block;
    background: #2563eb;
    color: #fff;
    padding: 0.85rem 2.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: background 0.2s;
  }
  .btn:hover {
    background: #1d4ed8;
  }
</style>


