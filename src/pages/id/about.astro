---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import WhatsApp from '../../components/WhatsApp.astro';
import data from '../../data/id/about.json';
---

<Layout title="Tentang Kami - Dakarash">
  <Navbar locale="id" />
  <main class="container">
    <section class="about">
      <h1>{data.heading}</h1>
      <p set:html={data.paragraph}></p>
    </section>
    <section class="visi-misi">
      <div class="visi">
        <h2>{data.vision_heading}</h2>
        <p>{data.vision_text}</p>
      </div>
      <div class="misi">
        <h2>{data.mission_heading}</h2>
        <ul>
          {data.mission_items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </section>
    <section class="hse">
      <h2>{data.hse_heading}</h2>
      <div class="grid">
        {data.hse_items.map((item) => (
          <div class="card">
            <h3>{item.title}</h3>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
  <WhatsApp />
  <Footer locale="id" />
</Layout>

<style>
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  .about h1 {
    font-size: 2.2rem;
    margin-bottom: 1.5rem;
    color: #0f172a;
  }
  .about p {
    color: #475569;
    line-height: 1.8;
    font-size: 1.1rem;
  }
  .visi-misi {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin: 3rem 0;
  }
  .visi, .misi {
    background: #f8fafc;
    padding: 2rem;
    border-radius: 12px;
  }
  .visi h2, .misi h2 {
    margin-bottom: 0.75rem;
    color: #0f172a;
  }
  .visi p, .misi li {
    color: #475569;
    line-height: 1.7;
  }
  .misi ul {
    padding-left: 1.25rem;
    margin: 0;
  }
  .misi li {
    margin-bottom: 0.5rem;
  }
  .hse {
    margin-top: 2rem;
  }
  .hse h2 {
    text-align: center;
    margin-bottom: 2rem;
    color: #0f172a;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .card {
    background: #fff;
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
  }
  .card h3 {
    margin-bottom: 0.5rem;
    color: #0f172a;
  }
  .card p {
    color: #64748b;
    line-height: 1.6;
  }
  @media (max-width: 768px) {
    .visi-misi { grid-template-columns: 1fr; }
    .grid { grid-template-columns: 1fr; }
  }
</style>


