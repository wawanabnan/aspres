---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsApp from '../components/WhatsApp.astro';

const serviceModules = import.meta.glob('../data/services/*.json', { eager: true });
const services = Object.values(serviceModules).map(m => m.default);
---

<Layout title="Layanan - Company Name">
  <Navbar />
  <main class="container">
    <h1>Layanan Kami</h1>
    <div class="grid">
      {services.map((item) => (
        <div class="service">
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </main>
  <WhatsApp />
  <Footer />
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 1rem;
  }
  h1 { text-align: center; margin-bottom: 2rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
  .service {
    background: #f8fafc;
    padding: 2rem;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
  }
  .service h3 { margin-bottom: 0.5rem; color: #1e293b; }
  .service p { color: #64748b; }
</style>
